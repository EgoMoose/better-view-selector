{
	"name": "better-view-selector-plugin",
	"tree": {
		"$className": "DataModel",
		"ReplicatedStorage": {
			"$className": "ReplicatedStorage",
			"PluginRoot": {
				"$path": "plugin.project.json"
			}
		},
		"StarterPlayer": {
			"$className": "StarterPlayer",
			"StarterPlayerScripts": {
				"$className": "StarterPlayerScripts",
				"Runner": {
					"$className": "LocalScript",
					"$properties": {
						"Source": "require(game.ReplicatedStorage.PluginRoot.Builds.PlayerGui).build(game.Players.LocalPlayer)"
					}
				}
			}
		}
	}
}